# ai-prd — AI-Powered PRD Generator
# Copy this file to .env and adjust values as needed.

# Prisma SQLite database URL (relative to prisma/ directory)
DATABASE_URL="file:./dev.db"

# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Recommended: Anthropic (Claude Sonnet) for best PRD generation quality.
ANTHROPIC_API_KEY=""

# Alternative providers (optional)
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
AGENTROUTER_API_KEY=""
OPENAI_COMPATIBLE_API_KEY=""
OPENAI_COMPATIBLE_BASE_URL=""
