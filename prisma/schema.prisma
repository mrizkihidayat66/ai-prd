generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("CLARIFYING") // CLARIFYING | REQUIREMENTS_LOCKED | GENERATING | PLAN_GENERATED | COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
  plan          Plan?
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String   // USER | ASSISTANT | SYSTEM
  content   String
  metadata  String?  // JSON string for tool calls, etc.
  createdAt DateTime @default(now())
}

model Plan {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version   Int      @default(1)
  content   String?  // Full PRD.md markdown document
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots PlanSnapshot[]
}

model PlanSnapshot {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  version   Int
  content   String   // Full PRD.md at this version
  createdAt DateTime @default(now())
}

model Settings {
  id           String   @id @default("default")
  provider     String   @default("anthropic") // openai | anthropic | google | ollama
  model        String   @default("claude-sonnet-4-20250514")
  customModels String?  // comma-separated custom model list
  apiKey       String?
  baseUrl      String?  // for Ollama or custom endpoints
  temperature  Float    @default(0.7)
  updatedAt    DateTime @updatedAt
}
